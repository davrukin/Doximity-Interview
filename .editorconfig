root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
ktlint_code_style = ktlint_official
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true
ktlint_function_naming_ignore_when_annotated_with = Composable
compose_allowed_composition_locals = LocalExtendedColors
max_line_length = 120
# Project convention (CLAUDE.md): block bodies everywhere; explicit public return types including Unit.
# These two ktlint rules enforce the opposite — disable them so the mechanical check matches the convention.
ktlint_standard_function-expression-body = disabled
ktlint_standard_no-unit-return = disabled
ktlint_standard_multiline-expression-wrapping = disabled
ktlint_standard_chain-method-continuation = disabled
ktlint_standard_function-signature = disabled
ktlint_standard_class-signature = disabled
ktlint_standard_parameter-list-wrapping = disabled

# Kotlin Code Style parameters for IntelliJ / ktlint formatting
ij_kotlin_method_parameters_wrap = on_every_item
ij_kotlin_method_call_arguments_wrap = on_every_item
ij_kotlin_class_constructor_parameters_wrap = on_every_item


[**/presentation/core/LaunchUseCase.kt]
# launchUseCase deliberately collects once per composition; restarting on lambda change is
# exactly what it exists to prevent.
ktlint_compose_lambda-param-in-effect = disabled

[*.{yml,yaml,json,toml}]
indent_size = 2
